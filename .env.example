# Variabili d'ambiente per l'area admin (impostale su Vercel → Project → Settings → Environment Variables)

# Password unica per accedere a /admin
ADMIN_PASSWORD=scegli-una-password-robusta

# Segreto per firmare il cookie di sessione (stringa lunga e casuale)
# Genera con:  openssl rand -base64 48
SESSION_SECRET=incolla-qui-una-stringa-casuale-lunga

# URL del Google Sheet collegato a Tally, pubblicato in formato CSV
# Google Sheets → File → Condividi → Pubblica sul web → CSV → copia il link
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXX/pub?output=csv

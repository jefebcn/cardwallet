# Variabili d'ambiente (Vercel → Project → Settings → Environment Variables)

# --- Area admin (/admin) ---

# Password unica per accedere a /admin
ADMIN_PASSWORD=scegli-una-password-robusta

# Segreto per firmare il cookie di sessione (stringa lunga e casuale)
# Genera con:  openssl rand -base64 48
SESSION_SECRET=incolla-qui-una-stringa-casuale-lunga

# Link del Google Sheet pubblicato in formato CSV (lettura iscritti nell'admin)
# Google Sheets → File → Condividi → Pubblica sul web → Foglio → CSV → copia il link
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXX/pub?output=csv

# --- Lista d'attesa (form nativo del sito, /api/subscribe) ---

# URL del Google Apps Script (web app) che accoda la riga al Google Sheet.
# Vedi README → "Lista d'attesa interna" per lo script pronto da incollare.
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# Segreto condiviso: deve combaciare con quello impostato nello script.
# Genera con:  openssl rand -base64 24
SHEET_WEBHOOK_SECRET=incolla-qui-un-secondo-segreto-casuale

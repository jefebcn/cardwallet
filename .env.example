# Variabili d'ambiente (Vercel → Project → Settings → Environment Variables)

# --- Area admin (/admin) ---

# Password unica per accedere a /admin
ADMIN_PASSWORD=scegli-una-password-robusta

# Segreto per firmare il cookie di sessione (stringa lunga e casuale)
# Genera con:  openssl rand -base64 48
SESSION_SECRET=incolla-qui-una-stringa-casuale-lunga

# --- Lista d'attesa (Supabase) ---

# Chiave anon di Supabase (scrittura su tabella waitlist). Pubblica per design:
# proteggere la tabella con Row Level Security (solo INSERT per il ruolo anon).
SUPABASE_ANON_KEY=incolla-qui-la-anon-key

# --- Email di conferma iscrizione (opzionale, via Resend) ---
# Se assente, l'iscrizione funziona ma non viene inviata alcuna email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Mittente (dominio da verificare su Resend)
WAITLIST_FROM_EMAIL=Crest <noreply@crestpay.app>
